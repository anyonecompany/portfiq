# Portfiq Environment Variables
# Copy to .env and fill in values

# Server
ENVIRONMENT=local
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# Anthropic (Claude API)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# External Data APIs
NEWS_API_KEY=
MARKET_DATA_API_KEY=

# Push Notifications (FCM)
FCM_SERVER_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Scheduler
BRIEFING_CRON_HOUR=6
BRIEFING_CRON_MINUTE=0

# Analytics
MIXPANEL_TOKEN=
